<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Separator?>

<VBox styleClass="dialog-panel" spacing="16" xmlns:fx="http://javafx.com/fxml"
      fx:id="settingsPanel" prefWidth="420">
    <Label styleClass="dialog-title" text="设置"/>
    <Separator/>
    <Label styleClass="dialog-label" text="默认模型"/>
    <ComboBox styleClass="model-selector" fx:id="settingsModelSelector" prefWidth="Infinity"/>
    <Label styleClass="dialog-label" text="API Key (DashScope)"/>
    <TextField styleClass="dialog-input" fx:id="settingsApiKey"
               promptText="留空则使用 DASHSCOPE_API_KEY 环境变量"/>
    <Label styleClass="dialog-label" text="API Base URL"/>
    <TextField styleClass="dialog-input" fx:id="settingsBaseUrl"
               promptText="https://dashscope.aliyuncs.com/compatible-mode/v1"/>
    <HBox spacing="12" alignment="CENTER_RIGHT">
        <Button styleClass="btn-icon" text="取消" fx:id="btnCancelSettings"/>
        <Button styleClass="btn-new-chat" text="保存" fx:id="btnSaveSettings"/>
    </HBox>
</VBox>
