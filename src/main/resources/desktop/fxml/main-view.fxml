<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ListView?>
<?import javafx.geometry.Insets?>

<BorderPane styleClass="main-container" xmlns:fx="http://javafx.com/fxml">
    <left>
        <VBox styleClass="sidebar" fx:id="sidebar">
            <HBox styleClass="sidebar-header" alignment="CENTER_LEFT" spacing="8">
                <Label styleClass="brand-title" text="✦ AI 助手"/>
            </HBox>
            <HBox fx:id="searchBox">
                <padding>
                    <Insets right="16" bottom="8" left="16"/>
                </padding>
                <TextField styleClass="search-field" fx:id="searchField"
                           promptText="搜索会话..." HBox.hgrow="ALWAYS"/>
            </HBox>
            <ListView styleClass="session-list" fx:id="sessionList" VBox.vgrow="ALWAYS"/>
            <HBox styleClass="sidebar-footer" alignment="CENTER_LEFT" spacing="8">
                <Button styleClass="btn-new-chat" text="＋ 新对话" fx:id="btnNewChat"
                        HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                <Button styleClass="btn-icon" text="⚙" fx:id="btnSettings"/>
            </HBox>
        </VBox>
    </left>

    <center>
        <SplitPane fx:id="centerSplitPane" orientation="HORIZONTAL"
                   SplitPane.resizableWithParent="true">
            <VBox styleClass="chat-area" fx:id="chatArea" minWidth="400">
                <HBox styleClass="chat-header" alignment="CENTER_LEFT">
                    <Label styleClass="chat-header-title" text="新对话" fx:id="chatHeaderTitle"/>
                </HBox>
                <ScrollPane styleClass="messages-scroll" fx:id="messagesScroll" fitToWidth="true" VBox.vgrow="ALWAYS">
                    <VBox styleClass="messages-container" fx:id="messagesContainer"/>
                </ScrollPane>
                <VBox styleClass="input-area">
                    <HBox styleClass="input-container" alignment="CENTER" spacing="8">
                        <ComboBox styleClass="model-selector" fx:id="modelSelector" prefWidth="160"/>
                        <Button styleClass="btn-attach" text="📎" fx:id="btnAttach"/>
                        <TextArea styleClass="chat-input" fx:id="chatInput"
                                  promptText="输入消息... (Enter 发送, Shift+Enter 换行)"
                                  prefRowCount="1" wrapText="true" HBox.hgrow="ALWAYS"/>
                        <Button styleClass="btn-send" text="▶ 发送" fx:id="btnSend"/>
                    </HBox>
                </VBox>
            </VBox>
        </SplitPane>
    </center>
</BorderPane>
